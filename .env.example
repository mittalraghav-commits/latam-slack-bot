# Slack App credentials (from api.slack.com → your app → Basic Information)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# LATAM API — base URL and access token (from the Appsmith dashboard config)
LATAM_API_BASE_URL=https://api.pocketfm.com/v3/content/internal
LATAM_API_KEY=QgsxEPWwrPCOmwflTJ1Y

# ── Language-based roles ───────────────────────────────────────────────────────
# Each variable holds the Slack usergroup ID for editors of that language.
# Members of LATAM_USERGROUP_ALL can update every language (super-admin).
# Leave a variable empty to disable access for that language.
#
# How to find a usergroup ID:
#   Slack → People & user groups → open group → ··· → Copy link
#   The ID starts with "S" (e.g. S012AB3CD)

LATAM_USERGROUP_ALL=        # super-admin: can update all languages
LATAM_USERGROUP_FR=         # French editors
LATAM_USERGROUP_DE=         # German editors
LATAM_USERGROUP_ES=         # Spanish editors
LATAM_USERGROUP_PT=         # Portuguese editors
